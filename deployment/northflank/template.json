{
  "apiVersion": "v1.2",
  "name": "ScopeTrace Demo Mode",
  "description": "OPTIONAL, best-effort Infrastructure-as-Code reference for a Demo Mode (DEMO_MODE=True) deployment of ScopeTrace on Northflank. See deployment/northflank/README.md before using this file -- several fields below are placeholders that MUST be confirmed against your own Northflank account (its free-tier plan IDs are not publicly documented as of this writing). The recommended path is the guided step-by-step UI walkthrough in deployment/northflank/CHECKLIST.md; this file is a secondary, faster-repeat option once you have deployed manually once and know your account's real plan IDs.",
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "ref": "project",
          "spec": {
            "name": "scopetrace-demo",
            "description": "ScopeTrace Demo Mode -- single web service, no worker/Beat. See docs/DEMO_DEPLOYMENT_PLAN.md."
          }
        },
        {
          "kind": "Workflow",
          "spec": {
            "type": "sequential",
            "context": {
              "projectId": "${refs.project.id}"
            },
            "steps": [
              {
                "kind": "Addon",
                "ref": "postgres",
                "spec": {
                  "type": "postgresql",
                  "name": "scopetrace-demo-db",
                  "version": "latest",
                  "billing": {
                    "deploymentPlan": "REPLACE_WITH_YOUR_ACCOUNT_FREE_TIER_DB_PLAN_ID",
                    "storage": 1024
                  }
                }
              },
              {
                "kind": "CombinedService",
                "ref": "webapp",
                "spec": {
                  "name": "scopetrace-demo-api",
                  "billing": {
                    "deploymentPlan": "REPLACE_WITH_YOUR_ACCOUNT_FREE_TIER_SERVICE_PLAN_ID"
                  },
                  "vcsData": {
                    "projectType": "github",
                    "projectUrl": "https://github.com/Utkarshum7/scopetrace-platform",
                    "projectBranch": "REPLACE_WITH_YOUR_DEPLOY_BRANCH"
                  },
                  "buildSettings": {
                    "dockerfile": {
                      "dockerFilePath": "backend/Dockerfile",
                      "dockerWorkDir": "backend"
                    }
                  },
                  "deployment": {
                    "instances": 1
                  },
                  "runtimeEnvironment": {
                    "DEBUG": "False",
                    "DEMO_MODE": "True",
                    "STORAGE_BACKEND": "s3",
                    "AWS_S3_REGION_NAME": "auto",
                    "AWS_S3_ADDRESSING_STYLE": "virtual",
                    "AI_ENABLED": "True",
                    "BOOTSTRAP_DATA": "true",
                    "BOOTSTRAP_DEMO_USERS": "true",
                    "RUN_MIGRATIONS": "true",
                    "DATABASE_URL": "${refs.postgres.connectionString}",
                    "ALLOWED_HOSTS": "REPLACE_WITH_YOUR_NORTHFLANK_SERVICE_HOSTNAME",
                    "CORS_ALLOWED_ORIGINS": "REPLACE_WITH_YOUR_DEMO_FRONTEND_ORIGIN",
                    "CSRF_TRUSTED_ORIGINS": "REPLACE_WITH_YOUR_NORTHFLANK_SERVICE_HTTPS_ORIGIN",
                    "AWS_S3_ENDPOINT_URL": "REPLACE_WITH_YOUR_R2_ACCOUNT_ENDPOINT",
                    "AWS_STORAGE_BUCKET_NAME": "REPLACE_WITH_YOUR_R2_BUCKET_NAME",
                    "DJANGO_SUPERUSER_USERNAME": "admin",
                    "DJANGO_SUPERUSER_EMAIL": "admin@scopetrace.local"
                  },
                  "ports": [
                    {
                      "name": "http",
                      "internalPort": 8000,
                      "protocol": "HTTP",
                      "public": true
                    }
                  ],
                  "healthChecks": {
                    "http": {
                      "path": "/healthz",
                      "port": 8000
                    }
                  }
                }
              },
              {
                "kind": "SecretGroup",
                "ref": "secrets",
                "spec": {
                  "name": "scopetrace-demo-secrets",
                  "type": "secret",
                  "secretType": "environment-arguments",
                  "secrets": {
                    "variables": {
                      "SECRET_KEY": "REPLACE_WITH_A_GENERATED_DJANGO_SECRET_KEY",
                      "AWS_ACCESS_KEY_ID": "REPLACE_WITH_YOUR_R2_ACCESS_KEY_ID",
                      "AWS_SECRET_ACCESS_KEY": "REPLACE_WITH_YOUR_R2_SECRET_ACCESS_KEY",
                      "DEMO_USER_PASSWORD": "REPLACE_WITH_A_CHOSEN_DEMO_USER_PASSWORD",
                      "DJANGO_SUPERUSER_PASSWORD": "REPLACE_WITH_A_CHOSEN_ADMIN_PASSWORD"
                    }
                  }
                }
              }
            ]
          }
        }
      ]
    }
  }
}
