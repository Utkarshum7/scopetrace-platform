# ==========================================
# ScopeTrace Monorepo gitignore
# ==========================================

# --- Python / Django ---
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/db.sqlite3
**/db.sqlite3-journal
**/staticfiles/
**/media/

# --- Python Virtual Environments ---
**/venv/
**/ENV/
**/env/
**/.venv/

# --- Node / React ---
**/node_modules/
**/dist/
**/.eslintcache
**/.parcel-cache
**/.cache/

# --- Environment Variables & Secrets ---
**/.env
**/.env.local
**/.env.*.local
**/*.env

# Allow env templates
!**/.env.example

# --- IDEs / Editors ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# --- OS Specific ---
Thumbs.db
desktop.ini
.DS_Store
