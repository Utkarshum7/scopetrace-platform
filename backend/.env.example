# ScopeTrace - Backend Environment Configuration Template
# Copy this file to .env and fill in real values before running the server.
# Never commit .env to version control.

# ------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-for-production
DEBUG=True
# Production: set DEBUG=False and list your Render hostname
ALLOWED_HOSTS=*,localhost,127.0.0.1

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# Local: SQLite is used automatically when DATABASE_URL is not set.
DATABASE_URL=sqlite:///db.sqlite3
# Production Render PostgreSQL (paste from Render dashboard → PostgreSQL → External URL):
# DATABASE_URL=postgres://user:password@hostname:5432/dbname

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
# Development: allow all origins
CORS_ALLOW_ALL_ORIGINS=True
# Production: set to False and list your exact Vercel domain
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://scopetrace.vercel.app

# ------------------------------------------------------------
# DJANGO SUPERUSER (Optional, for automatic seeding)
# ------------------------------------------------------------
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=yoursecurepassword
# DJANGO_SUPERUSER_EMAIL=admin@example.com
