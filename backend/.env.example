# ScopeTrace - Backend Environment Configuration Template
# Copy this file to .env and fill in real values before running the server.
# Never commit .env to version control.
#
# Configuration FAILS CLOSED: with DEBUG=False the app refuses to boot unless
# SECRET_KEY and DATABASE_URL are set, and it rejects wildcard ALLOWED_HOSTS.

# ------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------
# Local development can leave SECRET_KEY blank (an insecure dev key is used).
# Production: REQUIRED. Generate one, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=

# Optional (Phase 6f). Falls back to SECRET_KEY when unset — zero behavior
# change unless you explicitly want the JWT signing key rotatable
# independently of the key that signs sessions/CSRF tokens.
# JWT_SIGNING_KEY=

# DEBUG defaults to False. Set True only for local development.
DEBUG=True

# Comma-separated hosts. Wildcard '*' is rejected when DEBUG=False.
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------
# DEMO MODE (D4-D5) — an alternate deployment mode for free hosting with no
# Celery worker/Beat. See docs/DEMO_MODE_LATENCY.md and README's "Demo
# Deployment" section. False (default) = the full Production Mode this repo
# runs as everywhere else; nothing below this line changes when unset.
# ------------------------------------------------------------
# DEMO_MODE=False

# Bounded per-call AI provider request timeout, applied ONLY when
# DEMO_MODE=True (defaults to 30s then; None/unbounded in Production Mode).
# AI_PROVIDER_TIMEOUT_SECONDS=30

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# Local (DEBUG=True): leave blank to use SQLite automatically.
# Production (DEBUG=False): REQUIRED — must point at managed PostgreSQL.
# DATABASE_URL=postgres://user:password@hostname:5432/dbname
DATABASE_URL=

# ------------------------------------------------------------
# CORS  (locked down by default)
# ------------------------------------------------------------
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example:
# CORS_ALLOWED_ORIGINS=https://scopetrace.vercel.app
# CSRF_TRUSTED_ORIGINS=https://scopetrace.vercel.app

# ------------------------------------------------------------
# TLS TOGGLES (only read when DEBUG=False; default to fully hardened)
# Set these to False to run behind plain HTTP locally (e.g. Docker Compose).
# ------------------------------------------------------------
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ------------------------------------------------------------
# BOOTSTRAP / DJANGO SUPERUSER (used by `manage.py bootstrap_data`)
# ------------------------------------------------------------
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@scopetrace.local
# In production the admin is only created if a password is provided here.
# DJANGO_SUPERUSER_PASSWORD=change-me-to-a-strong-password

# entrypoint.sh runs bootstrap_data automatically when this is true.
# BOOTSTRAP_DATA=false

# Also seed one demo user per role (orgadmin/analyst/auditor/viewer).
# Requires DEMO_USER_PASSWORD to be set when DEBUG=False (fails closed --
# never creates publicly-documented-password accounts silently in prod).
# BOOTSTRAP_DEMO_USERS=false
# DEMO_USER_PASSWORD=change-me-to-a-strong-password

# ------------------------------------------------------------
# REDIS + CELERY (Phase 5 — async task queue; also the Phase 4 cache backend)
# ------------------------------------------------------------
# Redis — Django cache backend (Phase 4) AND Celery broker/result-backend
# default (Phase 5). Leave unset locally to use the in-memory cache and force
# CELERY_TASK_ALWAYS_EAGER (tasks run inline, no worker/broker needed).
# REDIS_URL=redis://localhost:6379/0

# Only set these if the broker/backend should differ from REDIS_URL.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Defaults to True when DEBUG=True or under the test runner (tasks run
# synchronously, no broker required). Set explicitly to False to force real
# async dispatch against a running worker even in DEBUG.
# CELERY_TASK_ALWAYS_EAGER=False

# CELERY_TASK_DEFAULT_QUEUE=celery

# ------------------------------------------------------------
# DURABLE FILE STORAGE (Phase 5b) — StorageService abstraction
# ------------------------------------------------------------
# 'local' (default when DEBUG=True) uses the filesystem under MEDIA_ROOT —
# dev/test only. Production (DEBUG=False) REQUIRES 's3' (also used for
# Cloudflare R2 / Backblaze B2 / MinIO — all speak the S3 API).
# STORAGE_BACKEND=local

# Only used by the local backend, to build fully-qualified download URLs.
# MEDIA_BASE_URL=http://localhost:8000

# Required when STORAGE_BACKEND=s3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=auto
# Blank = real AWS S3. Set for R2/B2/MinIO, e.g. http://minio:9000 in Compose.
# AWS_S3_ENDPOINT_URL=
# 'virtual' for AWS S3/R2/B2, 'path' for MinIO.
# AWS_S3_ADDRESSING_STYLE=virtual
# AWS_S3_URL_EXPIRE_SECONDS=3600

# ------------------------------------------------------------
# EMAIL NOTIFICATIONS (Phase 5g) — see docs/NOTIFICATIONS.md
# ------------------------------------------------------------
# Leave EMAIL_HOST unset to use the console backend (notifications are
# logged, not delivered) — a safe default even in production, since
# sending a notification is a side effect of a batch finishing, never a
# requirement for the pipeline itself to work.
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# EMAIL_TIMEOUT=10
# DEFAULT_FROM_EMAIL=noreply@scopetrace.local

# ------------------------------------------------------------
# CELERY BEAT / MAINTENANCE TASK TUNING (Phase 5f) — all optional,
# see docs/SCHEDULED_TASKS.md
# ------------------------------------------------------------
# STALE_BATCH_THRESHOLD_MINUTES=30
# FAILED_TASK_LOG_RETENTION_DAYS=90
# CELERY_HEARTBEAT_TTL_SECONDS=180

# ------------------------------------------------------------
# AI FOUNDATION (Phase 7a) — apps.ai. See docs/AI_ARCHITECTURE.md and
# docs/DEPLOYMENT_GUIDE.md §4.6 for the full reference.
# ------------------------------------------------------------
# Global kill switch — apps.ai is entirely inert (no provider ever
# constructed, no cost, no egress) until this is explicitly True.
# AI_ENABLED=False

# 'echo' | 'anthropic' | 'openai'. Defaults to 'echo' in DEBUG/tests
# (a real adapter with no network calls, for deterministic local dev and
# CI), else unset — NOT fail-closed the way STORAGE_BACKEND is, since
# AI_ENABLED=False is the actual production-safe default.
# AI_PROVIDER=echo

# Platform default; a TenantAIPolicy.model_override wins per-org.
# AI_DEFAULT_MODEL=claude-sonnet-5

# REDACTED | RAW | NO_EGRESS — see docs/AI_ARCHITECTURE.md.
# AI_DEFAULT_EGRESS_TIER=REDACTED

# Platform default; a TenantAIPolicy.monthly_budget_usd wins per-org.
# AI_DEFAULT_MONTHLY_BUDGET_USD=50.00

# Required when AI_PROVIDER=anthropic / =openai respectively, and only
# once a tenant actually has AI enabled.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Phase 7a.5 — apps.ai.evaluation's LLM-as-Judge framework (Tier 2,
# advisory). False by default: framework only, no production usage
# unless explicitly enabled.
# AI_JUDGE_ENABLED=False
